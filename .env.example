# Grief Matters CMS - Sanity Studio Environment Variables
# Copy this file to .env and fill in the secret values.

# Sanity CMS (public)
SANITY_STUDIO_PROJECT_ID="vg3sb730"
SANITY_STUDIO_DATASET="dev"
SANITY_STUDIO_API_VERSION="2023-07-16"

# Local API base URL (points to local worker in development)
SANITY_STUDIO_API_BASE_URL="http://localhost:8787"

# Sanity API auth token (secret) — request from maintainers
SANITY_API_AUTH_TOKEN=""
